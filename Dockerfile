# 1. استخدام نسخة Node.js مستقرة (زي اللي ظهرت في سجلاتك)
FROM node:18

# 2. تحديد المجلد اللي هيتحط فيه الكود جوه السيرفر
WORKDIR /app

# 3. نسخ ملفات تعريف المكتبات أولاً
COPY package*.json ./

# 4. تثبيت المكتبات (الخطوة دي هي اللي هتحل مشكلة 'module not found')
RUN npm install

# 5. نسخ كل ملفات المشروع (البوت، والمفاتيح، وغيرها)
COPY . .

# 6. الأمر النهائي لتشغيل البوت
CMD ["node", "bot.js"]
